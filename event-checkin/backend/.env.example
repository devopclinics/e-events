# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://checkin:checkin@db:5432/checkin

# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
JWT_SECRET=change-me-to-another-long-random-string

# ── App URLs (update to your domain) ──────────────────────────────────────────
# The Google OAuth callback must match what you register in Google Console
GOOGLE_REDIRECT_URI=https://events.vsgs.io/api/auth/google/callback
FRONTEND_URL=https://events.vsgs.io

# ── Google OAuth (get from console.cloud.google.com) ──────────────────────────
# Leave blank to disable Google sign-in
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── SMTP email ────────────────────────────────────────────────────────────────
# Leave SMTP_HOST blank to disable email sending
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=events@festio.events
SMTP_PASSWORD=your-mailbox-or-provider-password
SMTP_TLS=true
EMAIL_FROM=Festio <events@festio.events>
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=

# ── Twilio SMS ────────────────────────────────────────────────────────────────
# Leave TWILIO_ACCOUNT_SID blank to disable SMS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── Signal House US 10DLC SMS/MMS ────────────────────────────────────────────
# Set MESSAGING_PROVIDER=signalhouse; keep WHATSAPP_PROVIDER=bird when used.
MESSAGING_PROVIDER=
WHATSAPP_PROVIDER=
SIGNALHOUSE_API_KEY=
SIGNALHOUSE_FROM_NUMBER=
SIGNALHOUSE_API_BASE=https://v2.signalhouse.io
SIGNALHOUSE_STATUS_CALLBACK_URL=https://festio.events/api/messaging/signalhouse/status
