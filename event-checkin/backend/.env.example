# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://checkin:checkin@db:5432/checkin

# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
JWT_SECRET=change-me-to-another-long-random-string

# ── App URLs (update to your domain) ──────────────────────────────────────────
# The Google OAuth callback must match what you register in Google Console
GOOGLE_REDIRECT_URI=https://events.vsgs.io/api/auth/google/callback
FRONTEND_URL=https://events.vsgs.io

# ── FestioHub browser push notifications (VAPID) ─────────────────────────────
# Generate a separate VAPID key pair per environment. Keep the private key in
# your secret store; WEB_PUSH_ENABLED stays false until both keys are present.
WEB_PUSH_ENABLED=false
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
WEB_PUSH_VAPID_SUBJECT=mailto:events@festio.events

# ── Google OAuth (get from console.cloud.google.com) ──────────────────────────
# Leave blank to disable Google sign-in
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── SMTP email ────────────────────────────────────────────────────────────────
# Leave SMTP_HOST blank to disable email sending
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=events@festio.events
SMTP_PASSWORD=your-mailbox-or-provider-password
SMTP_TLS=true
EMAIL_FROM=Festio <events@festio.events>
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=

# ── Twilio SMS ────────────────────────────────────────────────────────────────
# Leave TWILIO_ACCOUNT_SID blank to disable SMS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── Signal House US 10DLC SMS/MMS ────────────────────────────────────────────
# Set MESSAGING_PROVIDER=signalhouse; keep WHATSAPP_PROVIDER=bird when used.
MESSAGING_PROVIDER=
WHATSAPP_PROVIDER=
SIGNALHOUSE_API_KEY=
SIGNALHOUSE_FROM_NUMBER=
SIGNALHOUSE_API_BASE=https://v2.signalhouse.io
SIGNALHOUSE_STATUS_CALLBACK_URL=https://festio.events/api/messaging/signalhouse/status

# ── Support service (Chatwoot + AI drafting) ────────────────────────────────
SUPPORT_AI_ENABLED=true
SUPPORT_AI_AUTO_SEND=false
SUPPORT_AI_AUTO_SEND_ORG_ALLOWLIST=
SUPPORT_AI_GATING_ENABLED=true
SUPPORT_LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
ZAI_API_KEY=
ZAI_BASE_URL=https://api.z.ai/api/paas/v4
ZAI_MODEL=glm-4.5-air
CHATWOOT_BASE_URL=http://chatwoot:3000
CHATWOOT_ACCOUNT_ID=
CHATWOOT_INBOX_ID=
CHATWOOT_API_ACCESS_TOKEN=
CHATWOOT_HMAC_SECRET=
CHATWOOT_WEBHOOK_TOKEN=
