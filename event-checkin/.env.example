# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.
#
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── Docker Hub credentials ────────────────────────────────────────────────────
# Create a personal access token at:
#   https://hub.docker.com/settings/security → "New Access Token"
# Use the token as DOCKER_PASSWORD (safer than your account password).
DOCKER_USERNAME=your_dockerhub_username
DOCKER_PASSWORD=your_dockerhub_access_token

# ── Database ──────────────────────────────────────────────────────────────────
DB_PASSWORD=change_me_use_a_strong_password

# ── Backup job ────────────────────────────────────────────────────────────────
# UID/GID of the host user that owns the ./backups directory.
# Run: id -u && id -g   to find your values.
BACKUP_UID=1000
BACKUP_GID=1000
BACKUP_RETENTION_DAYS=14

# ── Pipeline settings ─────────────────────────────────────────────────────────
# How many versioned tags to keep per service on Docker Hub.
# Tags beyond this count are deleted during each deploy.
KEEP_VERSIONS=3
